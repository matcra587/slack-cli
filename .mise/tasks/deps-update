#!/usr/bin/env bash
set -euo pipefail

query="${DEPS_UPDATE_QUERY:-patch}"

case "$query" in
patch | latest) ;;
*)
	echo "unsupported dependency update query: $query" >&2
	exit 2
	;;
esac

mods=()
while read -r path current; do
	[[ -n "$path" && -n "$current" ]] || continue

	update=""
	case "$query" in
	patch)
		current_core="${current%%-*}"
		[[ "$current_core" =~ ^(v[0-9]+\.[0-9]+\.)[0-9]+$ ]] || continue
		patch_prefix="${BASH_REMATCH[1]}"

		while read -r version; do
			version_core="${version%%-*}"
			[[ "$version_core" == "$patch_prefix"* ]] && update="$version"
		done < <(go list -m -versions -f '{{ range .Versions }}{{ . }}{{ "\n" }}{{ end }}' "$path")
		;;
	latest)
		update="$(go list -m -u -f '{{ if .Update }}{{ .Update.Version }}{{ end }}' "$path")"
		;;
	esac

	[[ -n "$update" && "$update" != "$current" ]] || continue
	mods+=("${path}@${update}")
done < <(go list -m -f '{{ if and (not .Main) (not .Indirect) }}{{ .Path }} {{ .Version }}{{ end }}' all)

if ((${#mods[@]} > 0)); then
	go get "${mods[@]}"
fi

go mod tidy
